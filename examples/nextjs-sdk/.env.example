# The Palai API key. SERVER-ONLY — it must never reach the browser. The Route Handler
# (app/api/palai/route.ts) is the sole holder: it talks to the control-plane with this
# Bearer token and re-projects canonical events to the browser. If it ever appeared in a
# browser request header, source map, or static chunk, that would be a Critical leak.
PALAI_API_KEY=palai-sk-replace-me

# Base URL of the Palai control-plane the SDK connects to (server-side). The deterministic
# browser proof points this at the local fake control-plane (tests/fake-control-plane.mjs);
# against a real stack, point it at the control-plane's public API.
PALAI_BASE_URL=http://127.0.0.1:8080
