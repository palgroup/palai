# compose.yaml interpolation contract. `palai local up` sets these from
# .palai/config.json; this file documents them for a hand-run `docker compose`.
# Secrets are NEVER set here — they live as files under .palai/ and reach the stack
# through the top-level `secrets:` block. Copy to compose.env and edit.

# Absolute path to the .palai data dir (holds ca/, api-key, runner-token, secrets/).
PALAI_HOME=/absolute/path/to/.palai

# Published host ports (bound to 127.0.0.1). Pick free ports.
PALAI_API_PORT=8080
PALAI_RUNNER_PORT=8443
PALAI_PG_PORT=5432
PALAI_S3_PORT=8333

# Reference engine image `palai local up` builds and passes to the runner.
PALAI_ENGINE_IMAGE=palai/reference-engine:local

# Optional: store:false retention TTL (Go duration, e.g. 24h). Empty disables reaping.
PALAI_RETENTION_STORE_FALSE_TTL=
