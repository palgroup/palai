# E14 T5 — the installation-level backup as a systemd oneshot, driven by palai-backup.timer.
# It runs the T4 `palai backup`: a consistent Postgres dump + object-store copy + manifest
# into one archive. `palai backup` reaches the running stack's containers BY NAME through the
# Docker socket (never host ports), so it works against the hardened production profile where
# only the TLS edge is published. See docs/operations/backup-restore.md.
#
# It reads .palai/config.json (via PALAI_HOME) for the project name and pg password, so it
# needs PALAI_HOME and Docker socket access — NOT the compose file. WorkingDirectory is the
# backup output dir: with no --out, `palai backup` writes palai-backup-<project>-<UTC>.tar.gz
# there. After a successful backup, ExecStartPost prunes old archives (retention example).

[Unit]
Description=Palai installation-level backup
Documentation=file:///opt/palai/docs/operations/backup-restore.md
Requires=docker.service
After=docker.service palai-stack.service
# Do not run the backup if the stack is not up — there would be nothing to dump.
Wants=palai-stack.service

[Service]
Type=oneshot
EnvironmentFile=/etc/palai/production.env
WorkingDirectory=/var/backups/palai
ExecStartPre=/bin/mkdir -p /var/backups/palai
ExecStart=/usr/local/bin/palai backup
# Retention: keep 14 days of archives, always keeping the newest (a real check, not a comment
# — proven by deploy/systemd/prune_test.go). Tune the day count to your RPO/retention policy.
ExecStartPost=/opt/palai/deploy/systemd/palai-backup-prune.sh /var/backups/palai 14
