#!/usr/bin/env bash
# Bring the packaged local stack up: build the palai CLI, initialise .palai on first run,
# then `local up` (build images, mint a fresh one-use runner token, compose up --wait).
# Volumes are retained across down/up; `scripts/local/down` stops without deleting them.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
cd "$root"

bin="$(mktemp -d)/palai"
go build -o "$bin" ./cmd/cli

home="${PALAI_HOME:-$root/.palai}"
test -f "$home/config.json" || PALAI_HOME="$home" "$bin" init
exec env PALAI_HOME="$home" "$bin" local up
