#!/usr/bin/env bash
# Regenerate into a scratch tree and diff against the committed generated
# output. Any drift (or an uncommitted schema edit) exits non-zero with the
# offending files, so CI blocks on stale generated sources.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
scratch="$(mktemp -d)"
trap 'rm -rf "$scratch"' EXIT

go run "$root/scripts/contracts/generator" -schemas "$root/protocols/schemas" \
  -go-out "$scratch/go" \
  -ts-out "$scratch/ts" \
  -py-out "$scratch/py"

go run "$root/scripts/contracts/semantic" -mode project \
  -canonical "$root/protocols/openapi/openapi-3.2.yaml" \
  -out "$scratch/openapi-3.1.2.yaml"

status=0
diff -r "$scratch/go" "$root/packages/contracts" || status=1
diff -r "$scratch/ts" "$root/protocols/generated/typescript" || status=1
diff -r "$scratch/py" "$root/protocols/generated/python" || status=1
diff "$scratch/openapi-3.1.2.yaml" "$root/protocols/generated/openapi-3.1.2.yaml" || status=1

if test "$status" -ne 0; then
  echo "generated sources are stale; run 'make generate'" >&2
fi

# The projection must stay semantically equivalent to the canonical 3.2 document.
if ! go run "$root/scripts/contracts/semantic" -mode diff \
  -canonical "$root/protocols/openapi/openapi-3.2.yaml" \
  -projection "$root/protocols/generated/openapi-3.1.2.yaml"; then
  echo "OpenAPI projection is not semantically equivalent to the canonical document" >&2
  status=1
fi

# Cross-language corpus round-trip: the generated TypeScript and Python checkers
# must agree with the Go conformance suite that every corpus document survives a
# decode/encode cycle (unknown fields and open enums preserved, omitted never
# collapses to null, 64-bit integers stay exact). A failure here aborts the run.
pnpm exec tsc --noEmit -p "$root/protocols/generated/typescript"
node --experimental-strip-types "$root/protocols/generated/typescript/corpus_check.ts"
PYTHONDONTWRITEBYTECODE=1 python3 "$root/protocols/generated/python/corpus_check.py"

exit "$status"
