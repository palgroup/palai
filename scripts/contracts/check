#!/usr/bin/env bash
# Regenerate into a scratch tree and diff against the committed generated
# output. Any drift (or an uncommitted schema edit) exits non-zero with the
# offending files, so CI blocks on stale generated sources.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
scratch="$(mktemp -d)"
trap 'rm -rf "$scratch"' EXIT

go run "$root/scripts/contracts/generator" -schemas "$root/protocols/schemas" \
  -go-out "$scratch/go" \
  -ts-out "$scratch/ts" \
  -py-out "$scratch/py" \
  -sdk-ts-out "$scratch/sdk-ts"

go run "$root/scripts/contracts/semantic" -mode project \
  -canonical "$root/protocols/openapi/openapi-3.2.yaml" \
  -out "$scratch/openapi-3.1.2.yaml"

status=0
# packages/contracts also holds handwritten, stdlib-only helpers (e.g. events.go)
# that the generator does not emit, so compare only the generated *.gen.go
# artifacts here rather than the whole directory — otherwise a hand-written helper
# reads as spurious drift. The comparison stays loud on real drift: a changed or
# missing generated file fails the diff, and an orphaned generated file (schema
# removed/renamed) fails the second pass. The TS/Py/OpenAPI roots are fully
# generated and stay whole-directory.
while IFS= read -r -d '' gen; do
  rel="${gen#"$scratch/go/"}"
  diff "$gen" "$root/packages/contracts/$rel" || status=1
done < <(find "$scratch/go" -type f -name '*.gen.go' -print0)
while IFS= read -r -d '' committed; do
  rel="${committed#"$root/packages/contracts/"}"
  if test ! -f "$scratch/go/$rel"; then
    echo "stale generated file not emitted by the generator: packages/contracts/$rel" >&2
    status=1
  fi
done < <(find "$root/packages/contracts" -type f -name '*.gen.go' -print0)
diff -r -x '__pycache__' -x '.DS_Store' "$scratch/ts" "$root/protocols/generated/typescript" || status=1
diff -r -x '__pycache__' -x '.DS_Store' "$scratch/py" "$root/protocols/generated/python" || status=1
# The SDK's generated transport types trace the same schemas; drift fails the diff.
diff "$scratch/sdk-ts/types.ts" "$root/sdks/typescript/src/generated/types.ts" || status=1
diff "$scratch/openapi-3.1.2.yaml" "$root/protocols/generated/openapi-3.1.2.yaml" || status=1

if test "$status" -ne 0; then
  echo "generated sources are stale; run 'make generate'" >&2
fi

# The projection must stay semantically equivalent to the canonical 3.2 document.
if ! go run "$root/scripts/contracts/semantic" -mode diff \
  -canonical "$root/protocols/openapi/openapi-3.2.yaml" \
  -projection "$root/protocols/generated/openapi-3.1.2.yaml"; then
  echo "OpenAPI projection is not semantically equivalent to the canonical document" >&2
  status=1
fi

# Cross-language corpus round-trip: the generated TypeScript and Python checkers
# must agree with the Go conformance suite that every corpus document survives a
# decode/encode cycle (unknown fields and open enums preserved, omitted never
# collapses to null, 64-bit integers stay exact). A failure here aborts the run.
pnpm exec tsc --noEmit -p "$root/protocols/generated/typescript"
node --experimental-strip-types "$root/protocols/generated/typescript/corpus_check.ts"
PYTHONDONTWRITEBYTECODE=1 python3 "$root/protocols/generated/python/corpus_check.py"

exit "$status"
