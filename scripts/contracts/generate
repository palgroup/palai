#!/usr/bin/env bash
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
go run "$root/scripts/contracts/generator" -schemas "$root/protocols/schemas" \
  -go-out "$root/packages/contracts" \
  -ts-out "$root/protocols/generated/typescript" \
  -py-out "$root/protocols/generated/python"

# Derive the OpenAPI 3.1.2 compatibility projection from the canonical 3.2 doc.
go run "$root/scripts/contracts/semantic" -mode project \
  -canonical "$root/protocols/openapi/openapi-3.2.yaml" \
  -out "$root/protocols/generated/openapi-3.1.2.yaml"
