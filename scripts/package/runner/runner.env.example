# Palai runner host env (E14 T5). Install to /etc/palai/runner.env and edit. This is the split-VM
# runner leg: this host runs ONLY the runner, dialing the control-plane VM's runner gateway.
# Secrets are FILES (never values here); the launcher derives enroll/session/renew URLs from
# PALAI_CONTROLLER_URL. See runner-host.md.

# The control-plane's runner-gateway URL (mTLS). Reachable from THIS runner host (a real
# two-VM deploy firewalls it to the runner subnet). Enroll(https)/session(wss) are derived from it.
PALAI_CONTROLLER_URL=https://controller.example.internal:8443

# The exact DNS identity in the controller gateway's server certificate — the runner pins it as
# the TLS ServerName regardless of the dial host, so it can differ from the URL host above.
PALAI_CONTROLLER_DNS=control-plane

# This runner's identity (unique per runner host).
PALAI_RUNNER_ID=runner-1
PALAI_RUNNER_DNS=runner-1.runners.palai.internal

# The controller CA the runner trusts — copy from the control-plane host's ${PALAI_HOME}/ca/ca.crt.
PALAI_RUNNER_CA_CERT=/etc/palai/runner/ca.crt

# One-use enrollment token FILE — copy from the control-plane host's ${PALAI_HOME}/runner-token.
# Mint a fresh one per enrollment on the control-plane side; the runner consumes it once.
PALAI_ENROLLMENT_TOKEN_FILE=/etc/palai/runner/runner-token

# The reference engine image the runner launches per lease. It must be pullable or pre-loaded on
# THIS host (the runner drives the local Docker socket to launch the engine sandbox).
PALAI_ENGINE_IMAGE=palai/reference-engine:local

# Concurrent lease slots on this runner (default 1).
PALAI_RUNNER_CONCURRENCY=1
