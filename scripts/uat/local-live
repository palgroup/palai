#!/usr/bin/env bash
# Local-live UAT: run the LP-001..015 cases through the packaged four-service stack via the
# `palai` CLI and capture the redacted evidence bundle. Deterministic (fake) cases prove the
# vertical slice with no network or credential; `make uat-local-live PROVIDER=provider-one`
# additionally runs the live-provider cases (LP-003/LP-004) create -> gateway -> runner -> OCI
# engine -> real provider -> terminal, with the credential loaded from .env.local at runtime.
# The live round-trip is its own protected run: not in make verify, not in the -count=3 loop.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
cd "$root"
exec scripts/evidence/capture
