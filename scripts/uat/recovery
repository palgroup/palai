#!/usr/bin/env bash
# Recovery UAT — the E10 exit gate. One target, a deterministic/component/fault CORE (always) + a
# named-but-gated live tier. The core is provider-agnostic: the kill is real, the provider is fake.
#
#   deterministic core (always):
#     1. TestCodingJourneyWithKillRecoveryDeterministic — the §63.2 kill+recovery coding journey: the
#        real orchestrator + tools + ladder with a REAL engine SIGKILL at the push boundary and a
#        compatible-checkpoint RESTORE, proving "recovery evidence complete, no duplicate tool/push/PR"
#        against the faithful Git double with the FAKE provider and NO credential. Routed through the
#        responses e2e infra it already provisions (throwaway Postgres + reference-engine subprocess).
#     2. test-fault CASE=recovery — the recovery fault suite: real container/host kills + uncertain-tool
#        reconciliation (duplicate external effect = 0), against real containers + real Postgres.
#     3. evidence-verify RELEASE=recovery-0.1.0 — the committed recovery bundle verifies clean with the
#        §26.12 RecoveryProof rule active (a recovery-claimed case with a missing/incomplete proof fails).
#
#   live tier (PROVIDER=provider-one): FOUR live-provider CASEs are authored + wired
#     (scripts/test/live-provider): checkpoint-restore (T4), container-kill-recovery (T5),
#     host-kill-restore (T6), detached-child-conversation (T8). dispatchModel now advertises the run's
#     effective tool set (E12 T1), so three of them drive a real spontaneous tool boundary against the
#     provider; host-kill-restore additionally needs the container-engine live harness (a named follow-up)
#     and SKIPs until it lands. They serialize on the shared :local Docker stack, so this target runs them
#     per-case in sequence when PROVIDER=provider-one (each SKIPs cleanly without .env.local creds).
#
#     The other three recovery halves have NO live-provider CASE authored — checkpoint-create (T1),
#     steer-survives-kill (T2), and tool-replay-reconcile (T7). They are proven at the fault/component
#     tier only (T7 recorded its own non-wiring deviation, tool_replay_fault_test.go:19-21); wiring their
#     live layer is a named follow-up, not an existing-but-gated CASE. This target does not claim them.
#
# uat-coding / uat-local-live / uat-interactive stay UNTOUCHED.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
cd "$root"

# Core 1 — the kill+recovery coding journey through the responses e2e infra.
E2E_RUN='TestCodingJourneyWithKillRecoveryDeterministic' TEST=responses scripts/test/e2e

# Core 2 — the recovery fault suite (real kills, provider-agnostic).
CASE=recovery scripts/test/fault

# Core 3 — the recovery-0.1.0 evidence bundle verifies clean.
RELEASE=recovery-0.1.0 scripts/evidence/verify

# Live tier — run the authored recovery live smokes per-case, serialized on the shared :local stack. Now
# that advertising landed (E12 T1) three drive a real spontaneous tool boundary; host-kill-restore SKIPs
# until the container-engine live harness lands (a named follow-up). Each SKIPs cleanly without creds. The
# other three halves (T1/T2/T7) have no live-provider CASE — named as a follow-up, not run.
if [ "${PROVIDER:-fake}" = "provider-one" ]; then
  for recovery_case in checkpoint-restore container-kill-recovery detached-child-conversation host-kill-restore; do
    echo "uat-recovery: live case $recovery_case" >&2
    PROVIDER=provider-one CASE="$recovery_case" scripts/test/live-provider
  done
  echo "uat-recovery: no live-provider CASE authored for checkpoint-create (T1), steer-survives-kill (T2), tool-replay-reconcile (T7) — proven at the fault/component tier; wiring their live layer is a named follow-up." >&2
fi
