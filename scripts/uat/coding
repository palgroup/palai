#!/usr/bin/env bash
# Repository-coding UAT — the E09 exit gate. One target, two tiers:
#   deterministic (always): TestCodingJourneyDeterministic composes the §63.2 coding journey
#     (bind -> prepare@exact-commit -> file/shell tool round-trip -> changeset -> model-driven
#     research child -> approved push + draft PR once) through the REAL orchestrator + tools +
#     composed steps against a FAITHFUL Git double, with the FAKE adapter and NO credential. It
#     writes + self-verifies the coding-0.1.0 bundle (the CI-provable external-receipt push +
#     the credential-absence scan). Routed through the responses e2e infra it already provisions.
#   live (PROVIDER=provider-one only): TestCodingLiveJourney drives the SAME journey against real
#     OpenAI + a real Git destination AT THE SEAM — the durable publication flows through the real
#     store (RequestPublication -> approved -> ApprovedPublicationsForRun -> RepositoryPublisher.Publish
#     -> real remote ref). The approve step is a direct durable-row transition, NOT the run-boundary
#     approve COMMAND (that boundary is proven deterministically + by T8 APV-001; wiring it into the
#     production HTTP run loop is E09 T10). It overwrites coding-0.1.0 with the real provider (chatcmpl)
#     + real external receipts. The credential loads from the git-ignored .env.local into this process
#     env only — never argv, log, or manifest. Without PROVIDER the live test skip-guards itself, so
#     this target is green in CI without a key. uat-local-live and uat-interactive stay untouched.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
cd "$root"
provider="${PROVIDER:-fake}"

# Deterministic tier: the coding journey through the responses e2e infra (throwaway Postgres +
# reference-engine subprocess, fake provider, faithful Git double). Reuse, not a second harness.
E2E_RUN='TestCodingJourneyDeterministic' TEST=responses scripts/test/e2e

# Live tier: only under provider-one. TestCodingLiveJourney is a seam-level e2e test (it reuses the
# responses newHarness for a real Postgres + a real run row, then drives a real provider + real Git
# destination through the real approve->publish path), so it rides the responses e2e infra (throwaway
# Postgres + reference-engine dir) via scripts/test/e2e — with the live credential + Git destination +
# shell image loaded into the environment the go test child inherits. The credential rides env only and
# the test asserts it absent from the bundle by construction. Real draft PRs need a GitHub App
# installation (PALAI_GITHUB_APP_ID/INSTALLATION_ID/PRIVATE_KEY_FILE + PALAI_GITHUB_REPO=owner/repo);
# without the App env the journey does a push-only external receipt against PALAI_GIT_REPO.
if [ "$provider" = "provider-one" ]; then
  if [ -f .env.local ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env.local
    set +a
  fi
  if [ -z "${OPENAI_API_KEY:-}" ]; then
    echo "OPENAI_API_KEY is unset; provider-one needs it in .env.local" >&2
    exit 1
  fi
  if [ -z "${PALAI_GIT_REPO:-}" ]; then
    echo "PALAI_GIT_REPO is unset; the live coding journey pushes to a real Git destination (set it in .env.local)" >&2
    exit 1
  fi
  # Pin the busybox shell image the OCI shell tool runs the model's argv in (matches scripts/test/live-provider).
  shell_ref="busybox@sha256:9532d8c39891ca2ecde4d30d7710e01fb739c87a8b9299685c63704296b16028"
  docker pull --quiet "$shell_ref" >/dev/null
  PALAI_SHELL_IMAGE_ID="$(docker image inspect "$shell_ref" --format '{{.Id}}')"
  export PALAI_SHELL_IMAGE_ID PALAI_UAT_PROVIDER=provider-one
  # E2E_RUN scopes the responses e2e run to the live journey; scripts/test/e2e provisions the throwaway
  # Postgres + engine dir the newHarness needs, and the go test child inherits the exported live env.
  exec env E2E_RUN='TestCodingLiveJourney' TEST=responses COUNT=1 scripts/test/e2e
fi
