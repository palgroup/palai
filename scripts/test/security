#!/usr/bin/env bash
# Security test tier: supervises the fixture engine in a real digest-pinned OCI
# container and proves the untrusted engine receives only an exact environment
# allowlist (no provider/DB/object-store/runner secret, no Docker socket, no runner
# key), that stderr is redacted and bounded independently of stdout, and that the
# container is unfindable by allocation ID once destroyed. Selected with
# `make test-security TEST=<suite>`; defaults to the runner suite. Repeat-count is
# COUNT. Kept out of `make verify`/`make test-unit` (Docker-bound).
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

# shellcheck source=scripts/test/runner-engine.sh
source "$root/scripts/test/runner-engine.sh"

# Default runs the engine-isolation suite, the E09 Task 4 workspace shell-tool suite, the E12 Task 6 MCP
# confused-deputy corpus, and the E12 Task 7 skill security corpus; select one with
# TEST=runner|sandbox|extensions|skills.
suites="${TEST:-runner sandbox extensions skills}"

run_runner() {
  run_runner_suite security ./tests/security/runner
}

# The skills suite is the E12 Task 7 capability-boundary corpus (spec §28.15-28.16, TOL-011): malicious
# archives are hard-rejected + a prompt-injection SKILL.md is installable but flagged for nothing (the
# quarantine + scan half, in the extensions package), and a skill grants no authority (the resolver's
# no-authority test, in the execution package). Pure Go — Quarantine + Resolve are internal-package
# symbols, so the corpus runs in-package (the internal-import constraint keeps it out of tests/), selected
# by name; it needs no Docker fixture engine.
run_skills() {
  go test -count=1 -v -run 'TestSkillSecurity' ./apps/control-plane/internal/extensions
  go test -count=1 -v -run 'TestSkillInstructionsGrantNoCapability' ./apps/control-plane/internal/execution
  echo "security_skills=PASS"
}

# The sandbox suite proves the workspace shell tool's isolation (spec §28.8, SAN-002/004): argv-form,
# unprivileged uid, no runtime socket, process-group kill on teardown, secret redaction, and metadata
# egress findings — all inside a real hardened OCI sandbox. It reuses the fixture-engine harness.
run_sandbox() {
  run_runner_suite security ./tests/security/sandbox
}

# The extensions suite is the E12 Task 6 MCP confused-deputy corpus (TOL-009/TOL-010): token replay/audience,
# received-credential-has-no-platform-authority, and a malicious sampling flood + fake-annotation all denied.
# It drives the real transport + sampling gate over loopback — no container, no Postgres — so it is a plain
# `go test`, not the fixture-engine harness.
run_extensions() {
  go test -count=1 ./tests/security/extensions
  # The E12 Task 8 hook capability-escalation corpus (spec §28.17, TOL-012): a transform patch grants no
  # capability, an unknown point cannot smuggle a hook, a credential cannot ride inline, and a remote hook
  # worker receives only the hook's own signing secret (the confused-deputy invariant). Store + strict
  # decoders are internal, so the corpus runs in-package (the internal-import constraint, the T7 precedent).
  go test -count=1 -v -run 'TestHookSecurity' ./apps/control-plane/internal/extensions
  echo "security_extensions_hooks=PASS"
}

for suite in $suites; do
  case "$suite" in
    runner) run_runner ;;
    sandbox) run_sandbox ;;
    extensions) run_extensions ;;
    skills) run_skills ;;
    *)
      echo "unknown security suite: $suite (known: runner, sandbox, extensions, skills)" >&2
      exit 2
      ;;
  esac
done
