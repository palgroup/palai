  provider-one/edge-admission)
    # E13 Task 7 (MCI-005, §20.12 basic tier): §20.12 edge admission control on a REAL router over a
    # throwaway Postgres. A rapid burst on one API key is shed by the per-key request-rate token bucket
    # (429 rate_limited), a burst of creates is shed by the per-project queued-run bound (429 queue_full)
    # with ZERO run lost or duplicated (one run+response per 202, none per 429), and an accepted run
    # DRAINS on the real provider-one — proving the shed queue is genuine. Needs the credential + a
    # throwaway Postgres + the reference engine (PALAI_ENGINE_DIR, exported by run_live_with_postgres).
    # Honest ceiling (named in the test): in-process token bucket (single-replica correct; distributed
    # limiter + weighted fairness QUO-002 is SaaS); the queued bound is a soft ReadCommitted count.
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveEdgeAdmissionBurstRateLimited"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  *)
    echo "unknown live-provider selector: PROVIDER=$provider CASE=$case_name" >&2
    echo "known: PROVIDER=provider-one CASE=text-stream-tool-schema, PROVIDER=provider-one CASE=workspace-mount, PROVIDER=provider-one CASE=artifact-write, PROVIDER=provider-one CASE=artifact-retrieval, PROVIDER=provider-one CASE=repository-clone, PROVIDER=provider-one CASE=subagents-isolated, PROVIDER=provider-one CASE=coding-tools, PROVIDER=provider-one CASE=agent-revision-run, PROVIDER=provider-one CASE=web-research-citations, PROVIDER=provider-one CASE=spontaneous-tool-roundtrip, PROVIDER=provider-one CASE=hook-deny-visible, PROVIDER=provider-one CASE=checkpoint-restore, PROVIDER=provider-one CASE=container-kill-recovery, PROVIDER=provider-one CASE=detached-child-conversation, PROVIDER=provider-one CASE=host-kill-restore, PROVIDER=provider-one CASE=trigger-dedupe-run, PROVIDER=provider-one CASE=cron-fires-once, PROVIDER=provider-one CASE=callback-once, PROVIDER=provider-one CASE=inbound-webhook-run, PROVIDER=provider-one CASE=registry-tool-roundtrip, PROVIDER=provider-one CASE=remote-tool-async-roundtrip, PROVIDER=provider-one CASE=mcp-tool-roundtrip, PROVIDER=provider-one CASE=mcp-sampling-budgeted, PROVIDER=provider-one CASE=skill-no-authority, PROVIDER=provider-one CASE=tenancy-isolation, PROVIDER=provider-one CASE=second-tenant-provisioning, PROVIDER=provider-one CASE=secret-rotation-restartless, PROVIDER=provider-one CASE=run-history-list, PROVIDER=provider-one CASE=edge-admission" >&2
    exit 2
    ;;
esac

# Load the credential into the environment at runtime. set -a exports every
# assignment in the file so the go test child inherits it; the source itself never
# echoes values, and set -x is off (see the header), so the secret never surfaces.
set -a
# shellcheck disable=SC1090
. "./$env_file"
set +a

if test -z "${!required_key:-}"; then
  echo "$env_file does not define $required_key for $provider" >&2
  exit 1
fi

# run_live_with_object_store stands up a throwaway Postgres + SeaweedFS (both under one label
# so the leak check counts them), exports their URLs, and runs the tagged test — which inherits
# the provider credential loaded above. Only the throwaway pg password rides a docker --env; the
# provider secret reaches the go test process only, never a container's argv or environment.
run_live_with_object_store() {
  local test_pkg="$1" test_run="$2"
  local pg_image="postgres@sha256:17e67d7b9890c99b055ba1e0d5c5be4ec27c9d3a72bda32db24a5e5d8a85af0c"
  # SeaweedFS digest matches ADR-0004 / deploy/compose/compose.yaml.
  local s3_image="docker.io/chrislusf/seaweedfs@sha256:c7d6c721b30ae711db766bbbfd40192776e263d4e51e22f57baef7bef93c12c6"
  local label="io.palai.live=artifact-write"
  local run_id="$$-${RANDOM}"
  local pg_container="palai-live-artifact-pg-$run_id"
  local s3_container="palai-live-artifact-s3-$run_id"
  local volume="palai-live-artifact-pg-$run_id"
  local password="palai-live-${RANDOM}${RANDOM}"

  count_containers() { docker ps -aq --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  count_volumes() { docker volume ls -q --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  cleanup() {
    docker rm -f "$pg_container" "$s3_container" >/dev/null 2>&1 || true
    docker volume rm -f "$volume" >/dev/null 2>&1 || true
  }
  local containers_before volumes_before
  containers_before="$(count_containers)"
  volumes_before="$(count_volumes)"
  trap cleanup EXIT

  docker volume create --label "$label" "$volume" >/dev/null
  docker run --detach --pull=never --name "$pg_container" --label "$label" \
    --env POSTGRES_DB=palai --env POSTGRES_PASSWORD="$password" \
    --publish 127.0.0.1::5432 --volume "$volume:/var/lib/postgresql/data" "$pg_image" >/dev/null
  docker run --detach --pull=never --name "$s3_container" --label "$label" \
    --publish 127.0.0.1::8333 "$s3_image" server -s3 -dir=/data >/dev/null

  local pg_ready=0
  for _ in $(seq 1 120); do
    if docker exec "$pg_container" pg_isready --username postgres --dbname palai >/dev/null 2>&1; then
      pg_ready=1
      break
    fi
    sleep 0.25
  done
  if test "$pg_ready" -ne 1; then
    docker logs "$pg_container" >&2 || true
    echo "postgres live-artifact container did not become ready" >&2
    exit 1
  fi

  local s3_binding s3_port
  s3_binding="$(docker port "$s3_container" 8333/tcp)"
  s3_port="${s3_binding##*:}"
  local s3_ready=0
  for _ in $(seq 1 120); do
    if curl -s -o /dev/null "http://127.0.0.1:$s3_port/"; then
      s3_ready=1
      break
    fi
    sleep 0.25
  done
  if test "$s3_ready" -ne 1; then
    docker logs "$s3_container" >&2 || true
    echo "seaweedfs live-artifact container did not become ready" >&2
    exit 1
  fi

  local pg_binding pg_port url
  pg_binding="$(docker port "$pg_container" 5432/tcp)"
  pg_port="${pg_binding##*:}"
  url="postgres://postgres:$password@127.0.0.1:$pg_port/palai?sslmode=disable"

  set +e
  PALAI_COMPONENT_POSTGRES_URL="$url" \
    PALAI_S3_ENDPOINT="http://127.0.0.1:$s3_port" \
    PALAI_S3_BUCKET="palai-artifacts-live" \
    PALAI_S3_ACCESS_KEY="palai" \
    PALAI_S3_SECRET_KEY="palai" \
    PALAI_ENGINE_DIR="$root/engines/reference" \
    go test -tags=live -count=1 -run "$test_run" -v "$test_pkg"
  local status=$?
  set -e
  if test "$status" -ne 0; then
    docker logs "$pg_container" >&2 || true
    docker logs "$s3_container" >&2 || true
  fi

  cleanup
  trap - EXIT
  local containers_after volumes_after
  containers_after="$(count_containers)"
  volumes_after="$(count_volumes)"
  if test "$containers_after" -ne "$containers_before" || test "$volumes_after" -ne "$volumes_before"; then
    echo "artifact-write live smoke leaked a container or volume" >&2
    exit 1
  fi
  return "$status"
}

# run_live_with_shell_image pins a busybox shell image (the E09 Task 4 coding-tool smoke needs a real
# shell so the model's argv runs — the fixture engine is scratch/san-only), exports its immutable
# daemon-resolved id, runs the tagged test (inheriting the credential loaded above), and verifies no
# sandbox container leaked. The provider secret reaches only the go test process, never a container.
run_live_with_shell_image() {
  local test_pkg="$1" test_run="$2"
  # Pinned busybox multi-arch manifest digest; the driver verifies the daemon-resolved image id.
  local shell_ref="busybox@sha256:9532d8c39891ca2ecde4d30d7710e01fb739c87a8b9299685c63704296b16028"
  local label="io.palai.sandbox"
  docker pull --quiet "$shell_ref" >/dev/null
  local image_id
  image_id="$(docker image inspect "$shell_ref" --format '{{.Id}}')"
  if [[ ! "$image_id" =~ ^sha256:[0-9a-f]{64}$ ]]; then
    echo "busybox shell image id is not immutable" >&2
    exit 1
  fi
  count_sandboxes() { docker ps -aq --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  local before after
  before="$(count_sandboxes)"
  set +e
  PALAI_SHELL_IMAGE_ID="$image_id" go test -tags=live -count=1 -run "$test_run" -v "$test_pkg"
  local status=$?
  set -e
  after="$(count_sandboxes)"
  if test "$after" -ne "$before"; then
    echo "coding-tools live smoke leaked a sandbox container" >&2
    exit 1
  fi
  return "$status"
}

