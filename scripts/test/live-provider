#!/usr/bin/env bash
# Live-provider test tier: the most protected tier. It runs the provider adapter
# against a REAL provider, so it needs the network and a real credential. The
# credential is loaded from the git-ignored .env.local into the process
# environment at runtime and never appears as a command argument, in a log, or in
# any captured output — the test asserts credential absence by construction, in
# process. Selected with `make test-live-provider PROVIDER=<p> CASE=<c>`. Kept out
# of `make verify`/`make test-unit` (network- and credential-bound).
#
# set -x must NEVER be enabled in this script: it would echo the sourced secret.
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

provider="${PROVIDER:-provider-one}"
case_name="${CASE:-text-stream-tool-schema}"
env_file=".env.local"

# The credential lives only in .env.local. Without it this tier cannot run, and it
# must fail loudly rather than silently pass a credential-free check.
if test ! -f "$env_file"; then
  echo "live-provider tier requires $env_file (git-ignored) with the provider credential; not found" >&2
  exit 1
fi

# Resolve the provider/case to a test package and a single test. Do this before
# loading the secret so an unknown selector fails without touching the credential.
# needs_engine=1 marks a case that also drives a real OCI engine container (the workspace-mount
# smoke), so the harness cross-builds the fixture engine and exports its digest-pinned image ID in
# addition to loading the credential.
needs_engine=0
needs_object_store=0
needs_shell_image=0
needs_postgres=0
needs_mcp=0
case "$provider/$case_name" in
  provider-one/text-stream-tool-schema)
    pkg="./tests/live/provider"
    run="TestLiveProviderOneTextStreamToolSchema"
    required_key="OPENAI_API_KEY"
    ;;
  provider-one/workspace-mount)
    # E09 Task 1: a real provider run bound to a real workspace allocation; the engine container
    # sees the real /workspace mount and the seeded file persists (proves the mount, not model
    # behaviour). Needs both the credential and the fixture engine image.
    pkg="./tests/live/workspace"
    run="TestLiveWorkspaceMountRealProviderRun"
    required_key="OPENAI_API_KEY"
    needs_engine=1
    ;;
  provider-one/subagents-isolated)
    # E09 Task 6: a real provider round-trip for a parent + a distinct-model child (the config-driven
    # delegation shape — two real chat-completion ids), plus T6's isolated-worktree + conflict-aware
    # merge on a REAL git repo (SUB-006 + REP-011). Honest ceiling: workspace provisioning is unwired,
    # so the provider calls and the worktree are not causally joined — enforcement is proven
    # deterministically; model-driven spawn is T7, provisioning-into-live-worktree is T9.
    pkg="./tests/live/subagents"
    run="TestLiveSubagentIsolatedWorktreeRealProvider"
    required_key="OPENAI_API_KEY"
    ;;
  provider-one/repository-clone)
    # E09 Task 3: clone a REAL Git repository at an exact commit through the infrastructure-owned
    # preparation and prove the brokered Git credential is absent from every surface (REP-003 live
    # half). Gated on PALAI_GIT_REPO; when the GitHub App env is present it mints a REAL installation
    # token. Honest ceiling: absence is the load-bearing invariant — an absence proof needs no
    # provider-realness, so this confirms with a REAL token what the deterministic tier proves with
    # a fake one. No provider completion is required (preparation is infrastructure-owned, §30.3).
    pkg="./tests/live/repository"
    run="TestLiveRepositoryCloneCredentialAbsent"
    required_key="PALAI_GIT_REPO"
    ;;
  provider-one/artifact-write)
    # E09 Task 2: a real provider completion's output is persisted as an artifact to a REAL
    # SeaweedFS + Postgres, then read back to prove row+bytes+checksum agree (LP §7.2). Needs the
    # credential and a throwaway object store + database. Honest ceiling: the LIVE element is a
    # real run writing real bytes to real S3, NOT model reasoning (the artifact tool is T4/T5).
    pkg="./apps/control-plane/internal/artifacts/live"
    run="TestLiveArtifactWriteRealProviderRun"
    required_key="OPENAI_API_KEY"
    needs_object_store=1
    ;;
  provider-one/artifact-retrieval)
    # E13 Task 5 (DAT-006 basic / MCI-004): a real provider completion's output is persisted as an artifact
    # to a REAL SeaweedFS + Postgres, then DOWNLOADED through the public HTTP retrieval API and proven
    # bit-identical to the produced file (the streamed bytes' checksum + the RFC 9530 Content-Digest agree
    # with what the write-path recorded). Needs the credential and a throwaway object store + database.
    # Honest ceiling (named in the test): the produced "file" is the run's completion output (the model-driven
    # file tool is registry work), and the download is an authenticated DIRECT stream — a pre-signed URL +
    # expiry ceremony is E13-H (DAT-006's remainder).
    pkg="./apps/control-plane/internal/artifacts/live"
    run="TestLiveArtifactRetrievalOverAPI"
    required_key="OPENAI_API_KEY"
    needs_object_store=1
    ;;
  provider-one/coding-tools)
    # E09 Task 4: the FIRST real multi-step tool loop. A real provider is FORCED (tool_choice:
    # required) to call the file tool then the shell tool; both execute through the production broker
    # seam — the file tool writes a real workspace, the shell tool reads it back inside a real
    # hardened OCI sandbox. Needs the credential and a pinned busybox shell image (the fixture engine
    # is scratch/san-only; a real shell lets the model's argv run). Honest ceiling named in the test.
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveCodingToolRoundTrip"
    required_key="OPENAI_API_KEY"
    needs_shell_image=1
    ;;
  provider-one/registry-tool-roundtrip)
    # E12 Task 2 (EXT-002/EXT-003): a control_plane echo tool REGISTERED in the durable extensibility
    # registry, pinned into a published set a run's agent revision names, is resolved through the broker's
    # per-tenant lookup and executed through the fenced ledger — driven by a REAL forced provider tool call.
    # Needs the credential + a throwaway Postgres for the registry rows. Honest ceiling (named in the test):
    # T1 advertising is NOT merged, so the call is FORCED (pre-T1 forced-seam); the spontaneous + advertising
    # half is proven deterministically and this case must be re-run once T1 merges. echo is pure — no
    # remote/MCP execution is claimed.
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveRegistryToolRoundtripForcedPreT1"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  provider-one/remote-tool-async-roundtrip)
    # E12 Task 4 (TOL-016/017 signed half): a REGISTERED remote_http tool, pinned into a published set a
    # run's AgentRevision names, is resolved through the broker's per-tenant lookup and executed as a SIGNED
    # HTTP invoke driven by a REAL provider-one tool call. The CP signs the tool-http.v1 invoke, a REAL local
    # harness server VERIFIES the HMAC, answers 202, and POSTs a REAL signed callback to the REAL callback
    # endpoint, which one-use-consumes the token and completes the operation — invoke -> 202 -> signed
    # callback -> completed proven end to end with real HMAC both directions. Needs the credential + a
    # throwaway Postgres (the operation + registry rows). Honest ceilings (named in the test): the call is
    # FORCED (pre-T1 seam, like registry-tool-roundtrip); the dispatchTool ledger-commit-under-fence + the
    # model CONTINUING on the callback result are proven DETERMINISTICALLY in the component tier and upgrade
    # live once T1b (engine-wire tool_call id) merges; the remote server is our harness. The HMAC secret is
    # in-process, never printed.
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveRemoteToolAsyncRoundtrip"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  provider-one/mcp-tool-roundtrip)
    # E12 Task 5 (TOL-008/EXT-006): an MCP connection to a REAL stdio server (the fixture, in a hardened,
    # network-less OCI container) is discovered → published → pinned into a set a run's AgentRevision names
    # with the connection in its mcp_connections rider → advertised to a REAL provider run → the model
    # SPONTANEOUSLY calls it → the call executes in an OCI-sandboxed server through the fenced path. Needs
    # the credential + a throwaway Postgres + the cross-built fixture MCP image. Honest ceiling (named in the
    # test): the "result → model CONTINUES" half needs T1b (engine-wire tool_call-id), not merged — proven
    # here is spontaneous-call + sandboxed-execution + canonical completion; re-run for continuation post-T1b.
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveMCPToolRoundtripSpontaneous"
    required_key="OPENAI_API_KEY"
    needs_mcp=1
    ;;
  provider-one/mcp-sampling-budgeted)
    # E12 Task 6 (TOL-010): a sampling-ENABLED MCP connection to a REAL stdio fixture (in a hardened,
    # network-less OCI container) triggers a server sampling/createMessage during a tools/call; the platform
    # routes it as a SEPARATE budgeted model step through a REAL provider-one Route, and a 1-token budget cuts
    # it off at Admit — asserted LIVE from the journalled step (a real chatcmpl id + reason budget_exceeded).
    # Needs the credential + the cross-built fixture MCP image (the throwaway Postgres from run_live_with_mcp
    # is unused by this smoke). Honest ceiling (named in the test): the MCP server is our fixture; what is REAL
    # is the provider Route + the live budget cutoff. The denial is a JSON-RPC error (the tools/call still
    # completes) and never trips the breaker.
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveMCPSamplingBudgetedCutoff"
    required_key="OPENAI_API_KEY"
    needs_mcp=1
    ;;
  provider-one/skill-no-authority)
    # E12 Task 7 (TOL-011): a REAL provider run with an ENABLED skill whose SKILL.md instructs "use the
    # push tool", pinned under an AgentRevision whose tool ceiling EXCLUDES push. The production
    # orchestrator freezes the skill pin, materializes the body into a real workspace (readable on-demand
    # via the file tool), and rides the metadata as a progressive-loading system message — yet push is
    # NEVER advertised and NEVER dispatched. Needs the credential + a throwaway Postgres + the reference
    # engine (the spontaneous-tool-roundtrip harness; run_live_with_postgres exports PALAI_ENGINE_DIR).
    # Honest ceiling (named in the test): the LOAD-BEARING invariant is the capability boundary (ZERO push
    # dispatches), NOT model behavior — whether the model reads/obeys the skill body is probabilistic
    # (logged, not required). Single provider; the resolver's no-authority drop is proven deterministically.
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveSkillNoAuthority"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  provider-one/agent-revision-run)
    # E11 Task 1 (AGT-001): a real provider run whose ExecutionSpec is resolved FROM a published
    # AgentRevision — the revision pins the model and its tool set is a capability CEILING. The real
    # request built from the resolved spec advertises ONLY the ceiling tool — the SAME set dispatchModel
    # now advertises (E12 T1) — and the real provider SPONTANEOUSLY calls it, coming back with a genuine
    # completion. Needs only the credential. Honest ceiling (named in the test): the "a tool outside the
    # revision is never offered" half is the advertised effective set; spontaneity is probabilistic, so a
    # green run is the proof.
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveAgentRevisionPinnedRun"
    required_key="OPENAI_API_KEY"
    ;;
  provider-one/web-research-citations)
    # E12 Task 3 (EXT-004, TOL-015): a real provider-one run resolves a research-only AgentRevision
    # ceiling (the publish tool excluded), FORCE-calls the research tool, and the tool executes a REAL
    # internet fetch of a public URL through the production broker seam — returning citations (final URL,
    # title, retrieved_at, content_hash over the raw bytes). Needs only the credential. Honest ceilings
    # (named in the test): there is NO search — the URL is given (search backend is E17); dispatchModel
    # does NOT advertise tool schemas, so the SPONTANEOUS-call half is proven by REQUEST CONSTRUCTION + a
    # FORCED call (E09 T4 seam) with "forced (T1 pending)" evidence, upgrading to spontaneous once E12 T1
    # lands; egress hits the real internet live (component-tier uses an injected resolver/dial + local
    # server). The publish tool never reaches the request — capability never expands (journey 63.4).
    pkg="./apps/control-plane/internal/execution/tools/live"
    run="TestLiveWebResearchCitations"
    required_key="OPENAI_API_KEY"
    ;;
  provider-one/spontaneous-tool-roundtrip)
    # E12 Task 1: the FIRST spontaneous real-provider tool call through the production orchestrator.
    # dispatchModel advertises the run's effective tool set (project default_tools = [palai.workspace.file]);
    # the real provider is offered the file tool, SPONTANEOUSLY calls it (the prompt instructs but does NOT
    # force — no tool_choice:required), and the broker executes it from the fenced ledger against a real
    # workspace. Evidence (ceiling 4 — what the test asserts): a real chatcmpl id on the spontaneous tool
    # step, the first committed result carries the tool call, a completed palai.workspace.file ledger row,
    # and the file actually on disk. Needs the credential + a throwaway Postgres + the engine dir. Honest
    # ceilings (named in the test): single provider (second-provider parity is E16); spontaneity is
    # probabilistic — a run where the model declines is red and re-runs, a green run IS the proof; the run
    # does NOT reach terminal completion here — the multi-step continuation re-threads the tool call +
    # result, which the engine wire (dropped tool_call id) makes malformed for the real chat API, a T1b
    # engine-wire tool_call-id follow-up (NOT an advertising gap).
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveSpontaneousToolRoundTripRealProvider"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  provider-one/hook-deny-visible)
    # E12 Task 8 (approved live smoke): the real provider SPONTANEOUSLY calls the advertised file tool, a
    # before_tool POLICY hook (platform_inline deny_all) DENIES it, and the model sees the structured
    # control-plane denial mid-run. Evidence (what the test asserts): the first committed result carries the
    # spontaneous tool call, a policy.denied.v1 event is journaled, NO completed palai.workspace.file ledger
    # row exists (a deny leaves no pre-write), and the workspace stays empty. Reuses the spontaneous-tool
    # harness (credential + throwaway Postgres + engine dir). Honest ceiling (named in the test): the hook
    # worker is OUR fixture (the deterministic deny_all handler) — what is proven live is the REAL model
    # seeing a REAL control-plane deny; spontaneity is probabilistic (a run where the model declines is red
    # and re-runs); single provider (provider-one), second-provider parity is E16.
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveHookDenyVisibleRealProvider"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  provider-one/checkpoint-restore)
    # E10 Task 4: a real provider forced-tool run persists a tool-boundary checkpoint to REAL S3, the
    # engine uv-subprocess is SIGKILLed post-persist, and a fresh attempt RESTORES it (ladder rung 2,
    # run.restore) and completes on the real provider — two DISTINCT chatcmpl ids + a complete §26.12
    # RecoveryProof + the completed tool not re-run. Needs the credential + a throwaway object store
    # (PG + SeaweedFS) + the engine dir. Honest ceilings (named in the test): the deterministic tier
    # already proves the ladder/restore/proof with a fake provider + hook kill. dispatchModel now
    # advertises the tool set (E12 T1) so the model spontaneously calls recovery_note, BUT this smoke
    # SKIPs on a multi-step tool-continuation follow-up: attempt 2's restored continuation re-threads the
    # tool call + result, which the engine wire (dropped tool_call id) makes malformed for the real chat
    # API — an engine-wire follow-up, not an advertising gap (advertising is proven by
    # CASE=spontaneous-tool-roundtrip).
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveCheckpointRestoreRealProvider"
    required_key="OPENAI_API_KEY"
    needs_object_store=1
    ;;
  provider-one/container-kill-recovery)
    # E10 Task 5: a real provider forced-tool run persists a tool-boundary checkpoint to REAL S3, the
    # engine is abruptly killed post-persist, and a fresh attempt RESTORES it (ladder rung 2) and
    # completes on the real provider — two DISTINCT chatcmpl ids + a complete §26.12 RecoveryProof +
    # the completed tool not re-run. Needs the credential + a throwaway object store (PG + SeaweedFS) +
    # the engine dir. Honest ceilings (named in the test): the container-kill dimension itself is proven
    # DETERMINISTICALLY against a real container in tests/fault/recovery (REC-001 + ENG-005). dispatchModel
    # now advertises the tool set (E12 T1) so the model spontaneously calls recovery_note, BUT this smoke
    # SKIPs on the same multi-step tool-continuation follow-up as checkpoint-restore (attempt 2 re-threads
    # the tool call + result; the engine wire drops the tool_call id) — an engine-wire follow-up, not an
    # advertising gap.
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveContainerKillRecoveryRealProvider"
    required_key="OPENAI_API_KEY"
    needs_object_store=1
    ;;
  provider-one/detached-child-conversation)
    # E10 Task 8: a real provider parent with a config-seeded DETACHED delegation RELEASES its compute
    # (a real checkpoint persisted to REAL S3 + run.waiting; no engine subprocess held), the child runs
    # as a durable job on the REAL provider, and the child terminal WAKES the parent, which RESTORES the
    # S3 checkpoint (ladder rung 2) and folds the typed result — two DISTINCT real chatcmpl ids, exactly
    # one child (rebind, never clone). Needs the credential + a throwaway object store (PG + SeaweedFS) +
    # the engine dir. Honest ceilings (named in the test): spawn is config-SEEDED (model-driven spontaneous
    # delegation is a later task, even though dispatchModel now advertises tools); the parent↔child
    # send_message conversation (DET-002) is proven deterministically, its live multi-step half a named
    # follow-up. The deterministic tier proves release/wake/rebind/exactly-once/addressing; this CONFIRMS
    # the DETACH+DURABLE half live.
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveDetachedChildConversationRealProvider"
    required_key="OPENAI_API_KEY"
    needs_object_store=1
    ;;
  provider-one/host-kill-restore)
    # E10 Task 6: a real provider run writes files to a REAL workspace, a pause cuts a checkpoint + a
    # workspace byte-snapshot to REAL S3, the WHOLE HOST is killed (runner daemon + engine sandbox
    # containers + host-path — single-machine stand-in), a fresh runner enrolls, the workspace RESTORES
    # (checksums re-derived EQUAL), and the run resumes + completes on the real provider — the fence pair
    # (old<new), the §26.12 RecoveryProof, and the fenced-out old host's stale frame DENIED. Needs the
    # credential + a throwaway object store (PG + SeaweedFS) + the engine dir. Honest ceilings (named in
    # the test): the FENCING + restore-under-real-kill half is proven DETERMINISTICALLY in
    # tests/fault/recovery/host_kill_test.go and the artifacts component tier; this tier confirms the
    # RESTORED workspace lets a real provider RESUME + COMPLETE. Tool advertising landed (E12 T1); the
    # remaining prerequisite is the container-engine live harness (engine in a real container, pause driven
    # through the runner path) — SKIPs until that harness lands (a named follow-up).
    pkg="./apps/control-plane/internal/execution/live"
    run="TestLiveHostKillRestoreRealProvider"
    required_key="OPENAI_API_KEY"
    needs_object_store=1
    ;;
  provider-one/trigger-dedupe-run)
