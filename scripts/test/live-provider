    # NO second run — a broker-seam request-count counter proves count==1. Needs the credential + a
    # throwaway Postgres (the dedupe is a partial-unique-index invariant). Honest ceiling (named in the
    # test): the source is manual/API (signed inbound is T5); the run's effective tool set is empty, so
    # dispatchModel advertises nothing and it stays single-step + real, making NO model→tool claim.
    pkg="./apps/control-plane/internal/automation/live"
    run="TestLiveTriggerDedupeRun"
    required_key="OPENAI_API_KEY"
    needs_postgres=1
    ;;
  provider-one/cron-fires-once)
    # E11 Task 3 (AUT-006/007/008): a due per-minute cron schedule on a cron trigger pinned to a published
    # AgentRevision fires through the SAME §20.2.2 pipeline; in the observed window EXACTLY ONE occurrence
    # bears EXACTLY ONE real provider-one run — a broker-seam request-count counter proves count ==
    # occurrence count. Needs the credential + a throwaway Postgres (exactly-once is a single-PG invariant).
    # Honest ceiling (named in the test): single machine, replicas share one PG (multi-host is E14); the
