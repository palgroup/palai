#!/usr/bin/env bash
# Fault-injection test tier. Selected with `make test-fault TEST=<suite>`; defaults to
# the coordinator suite. Repeat-count is COUNT (the plan gate runs it at 20). Kept out
# of `make verify`/`make test-unit` (Docker-bound).
#
#   coordinator  kills a durable-coordinator worker mid-lease against real PostgreSQL
#                and proves the lease is reclaimed at a higher fence while the killed
#                worker's completion is rejected.
#   subagents    cancels a parent run holding a live ChildRun against real PostgreSQL and
#                proves the cancel propagates to the child, the terminal accounting stays
#                consistent, and a late child completion is dropped at the database (SUB-005).
#   runner       supervises the fixture engine in a real digest-pinned OCI container
#                and proves a hung engine is force-killed and classified terminal, and
#                that malformed or oversized stdout fails the attempt safely.
#   recovery     supervises the fixture engine in a real container and proves the E10 kill
#                matrix's container half: a fast-exit engine's run.terminal is never lost in
#                the drain race (REC-001), and an external `docker rm -f` is classified lost.
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

# shellcheck source=scripts/test/runner-engine.sh
source "$root/scripts/test/runner-engine.sh"

suite="${TEST:-${CASE:-coordinator}}"

# Short, injected lease timer so the suite proves expiry/reclaim by database time
# without waiting on a production interval. The test reads it for both the claim and
# the heartbeat renewal.
export PALAI_FAULT_LEASE="${PALAI_FAULT_LEASE:-150ms}"

# run_pg_fault_suite spins a throwaway pinned-Postgres container, exports PALAI_FAULT_POSTGRES_URL,
# and runs the given fault package under -tags=fault, asserting no leaked container/volume. Both the
# coordinator (lease/fence) and subagents (child cancel propagation) suites share it.
run_pg_fault_suite() {
  local name="$1" pkg="$2"
  # Immutable pinned image (matches the postgres-coordinator spike / ADR-0001).
  local image="postgres@sha256:17e67d7b9890c99b055ba1e0d5c5be4ec27c9d3a72bda32db24a5e5d8a85af0c"
  local label="io.palai.fault=$name"
  local run_id="$$-${RANDOM}"
  local container="palai-fault-$name-$run_id"
  local volume="palai-fault-$name-$run_id"
  # Throwaway local credential, generated per run; never written to a file.
  local password="palai-fault-${RANDOM}${RANDOM}"

  count_containers() { docker ps -aq --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  count_volumes() { docker volume ls -q --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  cleanup() {
    docker rm -f "$container" >/dev/null 2>&1 || true
    docker volume rm -f "$volume" >/dev/null 2>&1 || true
  }

  local containers_before volumes_before
  containers_before="$(count_containers)"
  volumes_before="$(count_volumes)"
  trap cleanup EXIT

  docker volume create --label "$label" "$volume" >/dev/null
  docker run --detach --pull=never \
    --name "$container" \
    --label "$label" \
    --env POSTGRES_DB=palai \
    --env POSTGRES_PASSWORD="$password" \
    --publish 127.0.0.1::5432 \
    --volume "$volume:/var/lib/postgresql/data" \
    "$image" >/dev/null

  local ready=0
  for _ in $(seq 1 120); do
    if docker exec "$container" pg_isready --username postgres --dbname palai >/dev/null 2>&1; then
      ready=1
      break
    fi
    sleep 0.25
  done
  if test "$ready" -ne 1; then
    docker logs "$container" >&2 || true
    echo "postgres fault container did not become ready" >&2
    exit 1
  fi

  local binding port url
  binding="$(docker port "$container" 5432/tcp)"
  port="${binding##*:}"
  url="postgres://postgres:$password@127.0.0.1:$port/palai?sslmode=disable"

  set +e
  PALAI_FAULT_POSTGRES_URL="$url" \
    go test -tags=fault -count="${COUNT:-1}" -run "${PALAI_FAULT_RUN:-.}" -v "$pkg"
  local status=$?
  set -e
  if test "$status" -ne 0; then
    docker logs "$container" >&2 || true
  fi

  cleanup
  trap - EXIT
  local containers_after volumes_after
  containers_after="$(count_containers)"
  volumes_after="$(count_volumes)"
  if test "$containers_after" -ne "$containers_before" || test "$volumes_after" -ne "$volumes_before"; then
    echo "$name fault suite leaked a container or volume" >&2
    exit 1
  fi
  if test "$status" -ne 0; then
    exit "$status"
  fi
  echo "fault_$name=PASS containers=$containers_after volumes=$volumes_after"
}

run_coordinator() { run_pg_fault_suite coordinator ./tests/fault/coordinator; }

# run_subagents proves ChildRun cancel propagation + terminal accounting (SUB-005) against real
# Postgres: a parent cancel drives its live child to the canceled terminal, and a late child
# completion is dropped at the database rather than overwriting the canceled row.
run_subagents() { run_pg_fault_suite subagents ./tests/fault/subagents; }

# run_runner cross-builds the fixture engine into a digest-pinned `FROM scratch` image
# and supervises it through the real Moby driver, proving kill classification and JSONL
# bounds. The supervisor labels every sandbox container io.palai.sandbox=engine, so a
# leaked allocation is a non-zero delta after the run.
run_runner() {
  run_runner_suite fault ./tests/fault/runner
}

# The sandbox suite proves the workspace shell tool bounds resource exhaustion with a real memory
# cgroup: a memory hog is OOM-killed, a neighbour sandbox is intact, and the terminated run records
# its usage (spec §28.8, SAN-003). It reuses the fixture-engine harness.
run_sandbox() {
  run_runner_suite fault ./tests/fault/sandbox
}

# The recovery suite proves three E10 recovery halves under CASE=recovery. (1) The kill matrix's
# container half against the real fixture engine: a fast-exit engine's run.terminal is never lost in the
# OCI drain race (REC-001), an external `docker rm -f` mid-run is classified lost not a false success
# (ENG-005 streaming half), and T6's host-kill fences+restores. (2) T7's uncertain-tool reconciliation
# against real Postgres + a real local HTTP destination: a kill between a side-effecting tool's execute
# and record leaves the row uncertain, and the reconcile loop resolves it with DUPLICATE EXTERNAL EFFECT
# = 0 (reversible reconciles to completed; irreversible escalates to manual_resolution). No real provider
# — the reconcile invariant is provider-agnostic; the gated LIVE layer wraps the same assertions.
run_recovery() {
  run_runner_suite fault ./tests/fault/recovery
  # The reconcile fault tests live in package execution (they drive the in-process UncertainReconciler,
  # an internal package tests/fault/* cannot import — the E09 T2 placement rule). -run selects only the
  # fault-tagged recovery tests, so the package's plain unit tests are not re-run here.
  PALAI_FAULT_RUN='TestFaultReversibleReconcile|TestFaultIrreversibleReconcile' \
    run_pg_fault_suite recovery ./apps/control-plane/internal/execution
}

case "$suite" in
  coordinator) run_coordinator ;;
  subagents) run_subagents ;;
  runner) run_runner ;;
  sandbox) run_sandbox ;;
  recovery) run_recovery ;;
  *)
    echo "unknown fault suite: $suite (known: coordinator, subagents, runner, sandbox, recovery)" >&2
    exit 2
    ;;
esac
