  if test "$ready" -ne 1; then docker logs "$container" >&2 || true; echo "postgres skills container did not become ready" >&2; exit 1; fi
  local binding port url
  binding="$(docker port "$container" 5432/tcp)"
  port="${binding##*:}"
  url="postgres://postgres:$password@127.0.0.1:$port/palai?sslmode=disable"

  set +e
  # Quarantine + install-by-URL + digest + lifecycle (extensions package, component-tagged).
  PALAI_COMPONENT_POSTGRES_URL="$url" \
    go test -tags=component -count=1 -v -run 'Skill|ScanFailure' ./apps/control-plane/internal/extensions
  local status=$?
  # Run-start pin freeze + progressive-loading rider + workspace materialization + no-authority
