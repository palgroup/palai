#!/usr/bin/env bash
# Component test tier: exercises code against real backing services in throwaway
# Docker containers. Selected with `make test-component TEST=<suite>`; defaults to
# the postgres suite. Kept out of `make verify`/`make test-unit` (Docker-bound).
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

# shellcheck source=scripts/test/runner-engine.sh
source "$root/scripts/test/runner-engine.sh"

suite="${TEST:-postgres}"

# The runner suite proves a real workspace allocation is bind-mounted into a real, digest-pinned
# engine container (spec §29.9, E09 Task 1). It reuses the fault/security fixture-engine harness,
# which cross-builds the fixture, exports PALAI_RUNNER_ENGINE_IMAGE_ID, and verifies no sandbox
# container leaks.
run_runner() {
  run_runner_suite component ./tests/component/runner
}

run_postgres() {
  # Immutable pinned image (matches the postgres-coordinator spike / ADR-0001).
  local image="postgres@sha256:17e67d7b9890c99b055ba1e0d5c5be4ec27c9d3a72bda32db24a5e5d8a85af0c"
  local label="io.palai.component=postgres"
  local run_id="$$-${RANDOM}"
  local container="palai-component-postgres-$run_id"
  local volume="palai-component-postgres-$run_id"
  # Throwaway local credential, generated per run; never written to a file.
  local password="palai-component-${RANDOM}${RANDOM}"

  count_containers() { docker ps -aq --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  count_volumes() { docker volume ls -q --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  cleanup() {
    docker rm -f "$container" >/dev/null 2>&1 || true
    docker volume rm -f "$volume" >/dev/null 2>&1 || true
  }

  local containers_before volumes_before
  containers_before="$(count_containers)"
  volumes_before="$(count_volumes)"
  trap cleanup EXIT

  docker volume create --label "$label" "$volume" >/dev/null
  docker run --detach --pull=never \
    --name "$container" \
    --label "$label" \
    --env POSTGRES_DB=palai \
    --env POSTGRES_PASSWORD="$password" \
    --publish 127.0.0.1::5432 \
    --volume "$volume:/var/lib/postgresql/data" \
    "$image" >/dev/null

  local ready=0
  for _ in $(seq 1 120); do
    if docker exec "$container" pg_isready --username postgres --dbname palai >/dev/null 2>&1; then
      ready=1
      break
    fi
    sleep 0.25
  done
  if test "$ready" -ne 1; then
    docker logs "$container" >&2 || true
    echo "postgres component container did not become ready" >&2
    exit 1
  fi

  local binding port url
  binding="$(docker port "$container" 5432/tcp)"
  port="${binding##*:}"
  url="postgres://postgres:$password@127.0.0.1:$port/palai?sslmode=disable"

  set +e
  PALAI_COMPONENT_POSTGRES_URL="$url" \
    go test -tags=component -count=1 -v ./tests/component/postgres
  local status=$?
  # The E10 Task 2 redelivery-wiring tests drive the boundary pump against this same real spine
  # (unexported pumpCommands ⇒ package execution). -run selects only the component-tagged behavior
  # tests, so the package's Docker-free unit tests are not re-run here.
  if test "$status" -eq 0; then
    PALAI_COMPONENT_POSTGRES_URL="$url" \
      go test -tags=component -count=1 -v \
        -run 'TestApplied|TestRedelivery|TestPauseCheckpointCarriesBoundarySnapshot|TestPauseBoundaryCutsAndLinksSnapshotThroughOrchestrator|TestStuckWriterLeaseReclaimedAfterCrash|TestProvisioningInterruptedMidStateRecovers|TestPureToolReplay|TestIrreversibleUncertain|TestLateCallbackAfterFence|TestOutageCommandsDeliver|TestRecoveryProofCarries|TestStaleCommitOnReclaimer|TestDivergedContentReplay|TestPinnedRevision' \
        ./apps/control-plane/internal/execution
    status=$?
  fi
  # The E11 automation package drives against this same real spine: Task 1's agent-profile /
  # immutable-revision / template management + pin-resolution writes, and Task 4's webhook pump
  # fan-out -> signed real-HTTP delivery -> retry/dead-letter/redeliver state machine with real local
  # httptest receivers that verify the HMAC server-side (spec §21.4-21.6). Component-tagged.
  if test "$status" -eq 0; then
    PALAI_COMPONENT_POSTGRES_URL="$url" \
      go test -tags=component -count=1 -v ./apps/control-plane/internal/automation
    status=$?
  fi
  # The coordinator's admission pin-check (verifyPublishedRevision) has same-package component tests
  # that drive its query-error propagation against the real spine.
  if test "$status" -eq 0; then
    PALAI_COMPONENT_POSTGRES_URL="$url" \
      go test -tags=component -count=1 -v -run 'TestVerifyPublishedRevision' ./packages/coordinator
    status=$?
  fi
  set -e
  if test "$status" -ne 0; then
    docker logs "$container" >&2 || true
  fi

  cleanup
  trap - EXIT
  local containers_after volumes_after
  containers_after="$(count_containers)"
  volumes_after="$(count_volumes)"
  if test "$containers_after" -ne "$containers_before" || test "$volumes_after" -ne "$volumes_before"; then
    echo "postgres component suite leaked a container or volume" >&2
    exit 1
  fi
  if test "$status" -ne 0; then
    exit "$status"
  fi
  echo "component_postgres=PASS containers=$containers_after volumes=$volumes_after"
}

# The artifacts suite proves the S3 write-path (spec §22.6, LP §7.2 object-store carve-out)
# against a real SeaweedFS plus a real Postgres for the index rows: an artifact PUT records a
# row + object + checksum, a read is tenant-scoped, and the store:false retention purge deletes
# the artifact bytes. Both throwaway containers share one label so the leak check counts them.
run_artifacts() {
  local pg_image="postgres@sha256:17e67d7b9890c99b055ba1e0d5c5be4ec27c9d3a72bda32db24a5e5d8a85af0c"
  # SeaweedFS digest matches ADR-0004 / deploy/compose/compose.yaml (doctor pins the same).
  local s3_image="docker.io/chrislusf/seaweedfs@sha256:c7d6c721b30ae711db766bbbfd40192776e263d4e51e22f57baef7bef93c12c6"
  local label="io.palai.component=artifacts"
  local run_id="$$-${RANDOM}"
  local pg_container="palai-component-artifacts-pg-$run_id"
  local s3_container="palai-component-artifacts-s3-$run_id"
  local volume="palai-component-artifacts-pg-$run_id"
  # Throwaway local credential, generated per run; never written to a file.
  local password="palai-component-${RANDOM}${RANDOM}"

  count_containers() { docker ps -aq --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  count_volumes() { docker volume ls -q --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  cleanup() {
    docker rm -f "$pg_container" "$s3_container" >/dev/null 2>&1 || true
    docker volume rm -f "$volume" >/dev/null 2>&1 || true
  }

  local containers_before volumes_before
  containers_before="$(count_containers)"
  volumes_before="$(count_volumes)"
  trap cleanup EXIT

  docker volume create --label "$label" "$volume" >/dev/null
  docker run --detach --pull=never \
    --name "$pg_container" \
    --label "$label" \
    --env POSTGRES_DB=palai \
    --env POSTGRES_PASSWORD="$password" \
    --publish 127.0.0.1::5432 \
    --volume "$volume:/var/lib/postgresql/data" \
    "$pg_image" >/dev/null
  # SeaweedFS S3 gateway, anonymous (no configured identities — the doctor ping treats the
  # credential as immaterial); data lives in the container fs and is dropped on removal.
  docker run --detach --pull=never \
    --name "$s3_container" \
    --label "$label" \
    --publish 127.0.0.1::8333 \
    "$s3_image" server -s3 -dir=/data >/dev/null

  local pg_ready=0
  for _ in $(seq 1 120); do
    if docker exec "$pg_container" pg_isready --username postgres --dbname palai >/dev/null 2>&1; then
      pg_ready=1
      break
    fi
    sleep 0.25
  done
  if test "$pg_ready" -ne 1; then
    docker logs "$pg_container" >&2 || true
    echo "postgres artifacts container did not become ready" >&2
    exit 1
  fi

  local s3_binding s3_port
  s3_binding="$(docker port "$s3_container" 8333/tcp)"
  s3_port="${s3_binding##*:}"
  local s3_ready=0
  for _ in $(seq 1 120); do
    if curl -s -o /dev/null "http://127.0.0.1:$s3_port/"; then
      s3_ready=1
      break
    fi
    sleep 0.25
  done
  if test "$s3_ready" -ne 1; then
    docker logs "$s3_container" >&2 || true
    echo "seaweedfs artifacts container did not become ready" >&2
    exit 1
  fi

  local pg_binding pg_port url
  pg_binding="$(docker port "$pg_container" 5432/tcp)"
  pg_port="${pg_binding##*:}"
  url="postgres://postgres:$password@127.0.0.1:$pg_port/palai?sslmode=disable"

  set +e
  PALAI_COMPONENT_POSTGRES_URL="$url" \
    PALAI_S3_ENDPOINT="http://127.0.0.1:$s3_port" \
    PALAI_S3_BUCKET="palai-artifacts-component" \
    PALAI_S3_ACCESS_KEY="palai" \
    PALAI_S3_SECRET_KEY="palai" \
    go test -tags=component -count=1 -v ./apps/control-plane/internal/artifacts
  local status=$?
  set -e
  if test "$status" -ne 0; then
    docker logs "$pg_container" >&2 || true
    docker logs "$s3_container" >&2 || true
  fi

  cleanup
  trap - EXIT
  local containers_after volumes_after
  containers_after="$(count_containers)"
  volumes_after="$(count_volumes)"
  if test "$containers_after" -ne "$containers_before" || test "$volumes_after" -ne "$volumes_before"; then
    echo "artifacts component suite leaked a container or volume" >&2
    exit 1
  fi
  if test "$status" -ne 0; then
    exit "$status"
  fi
  echo "component_artifacts=PASS containers=$containers_after volumes=$volumes_after"
}

# The repository suite proves deterministic preparation (spec §30.3) and untrusted-repo containment
# (§30.4) against the host's real git — no container: the "real backing service" is git itself. It
# exercises the exact-commit receipt (REP-001) and the hostile-repo defenses (REP-002).
run_repository() {
  if ! command -v git >/dev/null 2>&1; then
    echo "git is required for the repository component suite" >&2
    exit 1
  fi
  go test -tags=component -count="${COUNT:-1}" -v ./tests/component/repository
  echo "component_repository=PASS"
}

# The mcp suite proves the E12 Task 5 MCP client (spec §28.13-28.14): migration 000026 + connection store +
# namespaced discovery + rider-gated dispatch (real Postgres), the advisory progress event (real Postgres),
# and the stdio transport + orphan sweep against a REAL, digest-pinned fixture MCP server in a hardened,
# network-less OCI container. It cross-builds the fixture (the runner-engine.sh idiom), exports its immutable
# image id, and verifies zero io.palai.sandbox=mcp containers leak.
run_mcp() {
  local pg_image="postgres@sha256:17e67d7b9890c99b055ba1e0d5c5be4ec27c9d3a72bda32db24a5e5d8a85af0c"
  local pg_label="io.palai.component=mcp"
  local mcp_label="io.palai.sandbox=mcp"
  local run_id="$$-${RANDOM}"
  local container="palai-component-mcp-pg-$run_id"
  local volume="palai-component-mcp-pg-$run_id"
  local password="palai-component-${RANDOM}${RANDOM}"
  local image_tag="palai-mcp-fixture:component"
  local build_dir="tests/sandboxes/mcp/.build"

  count_pg() { docker ps -aq --filter "label=$pg_label" | sed '/^$/d' | wc -l | tr -d ' '; }
  count_mcp() { docker ps -aq --filter "label=$mcp_label" | sed '/^$/d' | wc -l | tr -d ' '; }
  cleanup() {
    docker rm -f "$container" >/dev/null 2>&1 || true
    docker volume rm -f "$volume" >/dev/null 2>&1 || true
    local ids
    ids="$(docker ps -aq --filter "label=$mcp_label")"
    if test -n "$ids"; then docker rm -f $ids >/dev/null 2>&1 || true; fi
    docker image rm -f "$image_tag" >/dev/null 2>&1 || true
    rm -rf "$build_dir"
  }
  local pg_before mcp_before
  pg_before="$(count_pg)"
  mcp_before="$(count_mcp)"
  trap cleanup EXIT

  # Cross-build the digest-pinned fixture MCP server image for the daemon architecture.
  local daemon_os daemon_arch go_arch
  daemon_os="$(docker version --format '{{.Server.Os}}')"
  daemon_arch="$(docker version --format '{{.Server.Arch}}')"
  if test "$daemon_os" != linux; then
    echo "mcp suite requires a Linux Docker daemon, got $daemon_os" >&2
    exit 1
  fi
  case "$daemon_arch" in
    amd64 | x86_64) go_arch=amd64 ;;
    arm64 | aarch64) go_arch=arm64 ;;
    *) echo "unsupported Docker daemon architecture: $daemon_arch" >&2; exit 1 ;;
  esac
  rm -rf "$build_dir"
  mkdir -p "$build_dir"
  CGO_ENABLED=0 GOOS=linux GOARCH="$go_arch" \
    go build -trimpath -buildvcs=false -ldflags='-s -w' \
    -o "$build_dir/palai-mcp-fixture" ./tests/sandboxes/mcp
  docker build --platform "linux/$go_arch" --tag "$image_tag" \
    --file tests/sandboxes/mcp/Dockerfile "$build_dir" >/dev/null
  local image_id
  image_id="$(docker image inspect "$image_tag" --format '{{.Id}}')"
  if [[ ! "$image_id" =~ ^sha256:[0-9a-f]{64}$ ]]; then
    echo "Docker returned a non-immutable fixture image ID" >&2
    exit 1
  fi

  # Throwaway postgres.
  docker volume create --label "$pg_label" "$volume" >/dev/null
  docker run --detach --pull=never --name "$container" --label "$pg_label" \
    --env POSTGRES_DB=palai --env POSTGRES_PASSWORD="$password" \
    --publish 127.0.0.1::5432 --volume "$volume:/var/lib/postgresql/data" "$pg_image" >/dev/null
  local ready=0
  for _ in $(seq 1 120); do
    if docker exec "$container" pg_isready --username postgres --dbname palai >/dev/null 2>&1; then ready=1; break; fi
    sleep 0.25
  done
  if test "$ready" -ne 1; then docker logs "$container" >&2 || true; echo "postgres mcp container did not become ready" >&2; exit 1; fi
  local binding port url
  binding="$(docker port "$container" 5432/tcp)"
  port="${binding##*:}"
  url="postgres://postgres:$password@127.0.0.1:$port/palai?sslmode=disable"

  set +e
  # Store + migration + namespaced discovery + rider-gated dispatch (real Postgres, fake MCP client).
  PALAI_COMPONENT_POSTGRES_URL="$url" \
    go test -tags=component -count=1 -v ./apps/control-plane/internal/extensions
  local status=$?
  # The advisory progress event (real Postgres).
  if test "$status" -eq 0; then
    PALAI_COMPONENT_POSTGRES_URL="$url" \
      go test -tags=component -count=1 -v -run 'TestMCPProgressEmitsAdvisoryToolCallProgressEvent' ./packages/coordinator
    status=$?
  fi
  # The stdio transport + progress/cancel + orphan sweep against the REAL fixture container.
  if test "$status" -eq 0; then
    PALAI_MCP_FIXTURE_IMAGE_ID="$image_id" \
      go test -tags=component -count=1 -v ./adapters/integrations/mcp
    status=$?
  fi
  set -e
  if test "$status" -ne 0; then docker logs "$container" >&2 || true; fi

  cleanup
  trap - EXIT
  local pg_after mcp_after
  pg_after="$(count_pg)"
  mcp_after="$(count_mcp)"
  if test "$pg_after" -ne "$pg_before" || test "$mcp_after" -ne "$mcp_before"; then
    echo "mcp component suite leaked a container or volume" >&2
    exit 1
  fi
  if test "$status" -ne 0; then exit "$status"; fi
  echo "component_mcp=PASS pg=$pg_after mcp=$mcp_after"
}

case "$suite" in
  postgres) run_postgres ;;
  runner) run_runner ;;
  artifacts) run_artifacts ;;
  repository) run_repository ;;
  mcp) run_mcp ;;
  *)
    echo "unknown component suite: $suite (known: postgres, runner, artifacts, repository, mcp)" >&2
    exit 2
    ;;
esac
