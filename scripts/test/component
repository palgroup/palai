  if test "$containers_after" -ne "$containers_before" || test "$volumes_after" -ne "$volumes_before"; then
    echo "skills component suite leaked a container or volume" >&2
    exit 1
  fi
  if test "$status" -ne 0; then exit "$status"; fi
  echo "component_skills=PASS containers=$containers_after volumes=$volumes_after"
}

