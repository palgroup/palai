# The skills suite proves the E12 Task 7 quarantine → install-by-URL (real local TLS server) → digest
# pin → lifecycle (approve/enable, scan-blocks-enable) → run-start pin resolution against a real
# Postgres (spec §28.15-28.16, TOL-011). Component-tagged tests in the extensions + execution packages.
run_skills() {
  local image="postgres@sha256:17e67d7b9890c99b055ba1e0d5c5be4ec27c9d3a72bda32db24a5e5d8a85af0c"
  local label="io.palai.component=skills"
  local run_id="$$-${RANDOM}"
  local container="palai-component-skills-$run_id"
  local volume="palai-component-skills-$run_id"
  local password="palai-component-${RANDOM}${RANDOM}"

  count_containers() { docker ps -aq --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  count_volumes() { docker volume ls -q --filter "label=$label" | sed '/^$/d' | wc -l | tr -d ' '; }
  cleanup() {
    docker rm -f "$container" >/dev/null 2>&1 || true
    docker volume rm -f "$volume" >/dev/null 2>&1 || true
  }
  local containers_before volumes_before
  containers_before="$(count_containers)"
  volumes_before="$(count_volumes)"
  trap cleanup EXIT

  docker volume create --label "$label" "$volume" >/dev/null
  docker run --detach --pull=never --name "$container" --label "$label" \
    --env POSTGRES_DB=palai --env POSTGRES_PASSWORD="$password" \
    --publish 127.0.0.1::5432 --volume "$volume:/var/lib/postgresql/data" "$image" >/dev/null
  local ready=0
  for _ in $(seq 1 120); do
