{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.palai.dev/engine/engine.schema.json",
  "title": "EngineFrame",
  "type": "object",
  "required": ["protocol", "id", "type", "sequence", "time"],
  "properties": {
    "protocol": {"type": "string", "const": "engine.v1"},
    "id": {"$ref": "../schemas/common/id.json#/$defs/frame_id"},
    "type": {"type": "string"},
    "sequence": {"type": "integer", "minimum": 1},
    "time": {"type": "string", "format": "date-time"},
    "reply_to": {"type": ["string", "null"], "pattern": "^frm_[A-Za-z0-9_-]+$"},
    "run_id": {"$ref": "../schemas/common/id.json#/$defs/run_id"},
    "attempt_id": {"$ref": "../schemas/common/id.json#/$defs/attempt_id"},
    "data": {"type": "object"}
  },
  "additionalProperties": true,
  "$defs": {
    "controller_types": {
      "description": "Controller-to-engine frame types (spec §25.6 handshake + §25.7). Documented-open: an unsupported type produces a protocol.error, it is not rejected by the envelope (API-009).",
      "enum": [
        "supervisor.hello", "run.start", "run.restore", "message.deliver",
        "config.change", "model.result", "model.delta", "tool.result",
        "approval.result", "child.result", "checkpoint.request", "run.pause",
        "run.cancel", "protocol.ack"
      ]
    },
    "engine_types": {
      "description": "Engine-to-controller frame types (spec §25.6 handshake + §25.8). Documented-open: an unsupported type produces a protocol.error, it is not rejected by the envelope (API-009).",
      "enum": [
        "engine.ready", "engine.heartbeat", "progress", "output.delta",
        "output.item", "model.request", "tool.request", "child.request",
        "approval.request", "checkpoint.offer", "context.compacted", "warning",
        "protocol.error", "run.waiting", "run.terminal", "protocol.ack"
      ]
    },
    "limits": {"max_line_bytes": 1048576},
    "tool_call": {
      "description": "A tool the model asked to run, as it crosses the engine boundary. The provider emits arguments as a JSON string; the controller resolves it to an object exactly once before the frame is built, so the engine only ever sees an object (spec §25.9).",
      "type": "object",
      "required": ["name", "arguments"],
      "properties": {
        "name": {"type": "string"},
        "arguments": {"type": "object"}
      }
    }
  },
  "allOf": [
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "engine.ready"}}},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["selected_protocol", "engine", "max_frame_bytes", "nonce"],
            "properties": {
              "selected_protocol": {"type": "string"},
              "engine": {
                "type": "object",
                "required": ["name", "version"],
                "properties": {
                  "name": {"type": "string"},
                  "version": {"type": "string"}
                }
              },
              "max_frame_bytes": {"type": "integer", "minimum": 1},
              "nonce": {"type": "string"},
              "checkpoint_formats": {"type": "array", "items": {"type": "string"}},
              "commands": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "tool.request"}}},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["arguments"],
            "properties": {"arguments": {"type": "object"}}
          }
        }
      }
    },
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "model.result"}}},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "tool_calls": {"type": "array", "items": {"$ref": "#/$defs/tool_call"}}
            }
          }
        }
      }
    },
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "run.start"}}},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "required": ["input"],
            "properties": {
              "input": {"description": "This turn's user input (spec §25.10 step 2)."},
              "messages": {
                "description": "Prior-response conversation history the engine folds in before input (spec §9, §22.2). The controller assembles it from the session's earlier responses; a purged response is carried as a redacted_content marker, and a first response omits it.",
                "type": "array",
                "items": {"type": "object"}
              }
            }
          }
        }
      }
    },
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "child.request"}}},
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "workspace_mode": {
                "description": "The workspace a delegated child receives (spec §29.8, §30.5): none = no workspace (the E08 default); read_only = a read-only snapshot of the parent's; isolated = an isolated copy-on-write branch/worktree. The value is declared here in E09 Task 1 (schema-pin) and enforced in Task 6; before E09 it rode the frame Go/Py-only.",
                "type": "string",
                "enum": ["none", "read_only", "isolated"]
              }
            }
          }
        }
      }
    },
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "checkpoint.offer"}}},
      "then": {
        "properties": {
          "data": {
            "description": "An offered engine checkpoint (spec §26.1-26.2, E10 Task 1). state is the OPAQUE loop-state bytes base64-encoded; the control plane stores and checksums them but never interprets them (§26.2). format/format_version pin compatibility against engine.ready.checkpoint_formats; boundary_kind records why the offer was made (completed tool, pause, explicit request).",
            "type": "object",
            "required": ["format", "format_version", "state"],
            "properties": {
              "format": {"type": "string"},
              "format_version": {"type": "integer", "minimum": 1},
              "boundary_kind": {"type": "string", "enum": ["tool", "child", "pause", "request"]},
              "state": {"type": "string", "description": "base64 of the opaque checkpoint bytes"}
            }
          }
        }
      }
    },
    {
      "if": {"required": ["type"], "properties": {"type": {"const": "run.restore"}}},
      "then": {
        "properties": {
          "data": {
            "description": "Restore a fresh engine process from a portable checkpoint (spec §26.3 rung 2, E10 Task 4) — the inbound mirror of checkpoint.offer. state is the OPAQUE loop-state bytes base64-encoded (the same bytes the control plane held); format/format_version must match engine.ready.checkpoint_formats or the engine answers protocol.error rather than half-restoring. The engine re-derives the frame it was awaiting at the captured boundary.",
            "type": "object",
            "required": ["format", "format_version", "state"],
            "properties": {
              "format": {"type": "string"},
              "format_version": {"type": "integer", "minimum": 1},
              "state": {"type": "string", "description": "base64 of the opaque checkpoint bytes"}
            }
          }
        }
      }
    }
  ]
}
