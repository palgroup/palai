{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.palai.dev/execution/tool-set.json",
  "title": "ToolSet",
  "type": "object",
  "required": ["id", "object", "set", "revision_number"],
  "properties": {
    "id": {"$ref": "../common/id.json#/$defs/opaque_id"},
    "object": {"type": "string", "const": "tool_set_revision"},
    "organization_id": {"$ref": "../common/id.json#/$defs/organization_id"},
    "project_id": {"$ref": "../common/id.json#/$defs/project_id"},
    "set": {"type": "string"},
    "revision_number": {"type": "integer"},
    "digest": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
