{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.palai.dev/spikes/fixture.schema.json",
  "title": "Fixture",
  "type": "object",
  "required": [
    "id",
    "status",
    "metadata",
    "sequence",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "note": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "x-palai-known-values": [
        "queued",
        "running",
        "completed"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "sequence": {
      "type": "integer",
      "format": "int64",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
